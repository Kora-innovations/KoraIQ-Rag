# RAG Service Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it's in .gitignore)

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5

# LangSmith Configuration (for monitoring/tracing)
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=health-insurance-qa

# Tavily API (for web search, optional)
TAVILY_API_KEY=your_tavily_api_key_here

# Supabase Configuration (if using Supabase for vector storage)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here
SUPABASE_TABLE=hmo_documents
SUPABASE_QUERY_NAME=match_documents

# PostgreSQL Configuration (alternative to Supabase)
POSTGRES_URL=your_postgres_connection_string_here
# OR
DATABASE_URL=your_database_connection_string_here

# Token Management
MAX_HISTORY_TOKENS=1500
TOKEN_MODEL_FOR_COUNT=gpt-4o

# System Prompt
SYSTEM_PROMPT=You are a helpful, knowledgeable AI assistant. You provide accurate and well-researched answers to general questions. You are good at conversation, remember context, and can discuss a wide range of topics including technology, business, current events, and general knowledge. If a question is unclear, ask for clarification. Always be helpful, accurate, and engaging in your responses.

# Port (automatically set by Render, but you can override for local dev)
PORT=8002



